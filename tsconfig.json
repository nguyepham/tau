{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "src/*": [
                "./src/*"
            ]
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "checkJs": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "src/**/*"
    ]
}