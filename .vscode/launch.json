{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Zen CLI (interactive)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "args": ["dist/cli.mjs"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Zen CLI (print mode)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "args": ["dist/cli.mjs", "-p", "${input:prompt}"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Zen CLI (debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "args": ["dist/cli.mjs", "--debug"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Build (bun)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "args": ["run", "build.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "prompt",
      "type": "promptString",
      "description": "Enter your prompt for Zen"
    }
  ]
}
